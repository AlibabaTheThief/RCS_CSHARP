{
  "decks": [
    {
      "id": "phase0",
      "name": "Sounds & Alphabet",
      "phase": 0,
      "description": "Every letter of the Azerbaijani alphabet with an example word. Learn to read any word and pronounce it roughly right. ~1 week.",
      "enabledByDefault": true
    },
    {
      "id": "phase1",
      "name": "Dad & Family",
      "phase": 1,
      "description": "Pronouns, 'I am / you are', family words, greetings and the first heart phrases. ~2 weeks.",
      "enabledByDefault": true
    },
    {
      "id": "listening1",
      "name": "Listening — First Words",
      "phase": 1,
      "description": "Hear Azerbaijani, recall the meaning. The goal is spoken understanding.",
      "enabledByDefault": true
    },
    {
      "id": "dad",
      "name": "Phrases for Dad",
      "phase": 1,
      "description": "Your own phrases to say to Dad. Add one any time it occurs to you.",
      "enabledByDefault": true
    },
    {
      "id": "phase2",
      "name": "Everyday Survival",
      "phase": 2,
      "description": "Numbers, 'I have / want / like', food and home, present tense, question words. ~3–4 weeks.",
      "enabledByDefault": false
    },
    {
      "id": "patterns",
      "name": "Patterns",
      "phase": 2,
      "description": "Fill-in-the-blank patterns — swap the word to build your own sentences.",
      "enabledByDefault": false
    },
    {
      "id": "dialogues",
      "name": "Call with Dad",
      "phase": 1,
      "description": "Short scripted conversations you can run end-to-end, then say for real.",
      "enabledByDefault": false
    }
