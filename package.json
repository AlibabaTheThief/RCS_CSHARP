{
  "name": "azeri-for-dad",
  "version": "1.0.0",
  "private": true,
  "description": "A personal spaced-repetition flashcard PWA for learning Azerbaijani, built for Ali to talk with his Dad.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --host",
    "audio": "node scripts/generate-audio.mjs",
    "audio:gtts": "python3 scripts/generate_audio.py"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
